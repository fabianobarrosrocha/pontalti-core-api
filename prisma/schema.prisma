generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Users {
  id         Int      @id @default(autoincrement())
  email      String   @unique
  password   String
  name       String
  isAdmin    Boolean? @default(false)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
}

model Adresses {
  id             Int     @id @default(autoincrement())
  zip_code       String
  neighborhood   String
  public_place   String
  city           String
  state          String
  complement     String?
  address_number Int

  vendors   Vendors[]
  customers Customers[]
}

model Customers {
  id             Int      @id @default(autoincrement())
  status         Int
  address_id     Int
  credit_limit   Float
  debts          Float
  name           String
  phone          String
  cel_number     String
  email          String   @unique
  store_name     String
  deliver        Boolean
  pontalti       Boolean
  secondary_line Boolean
  cpf            String?  @unique
  cnpj           String?  @unique
  created_at     DateTime @default(now())
  updated_at     DateTime

  address Adresses @relation(fields: [address_id], references: [id])

  Order  Orders[]
  prices Prices[]

  messageConfig  CustomerMessageConfig[]
  packagings     CustomerPackaging[]
  salesForecasts SalesForecasts[]
  expenseActors  ExpenseActor[]
}

model Employees {
  id             Int       @id @default(autoincrement())
  email          String    @unique
  name           String
  phone          String
  cel_number     String
  cpf            String    @unique
  classification Int
  admission      DateTime
  salary         Float?
  dismissal_date DateTime?
  created_at     DateTime  @default(now())
  updated_at     DateTime  @updatedAt

  schedules              Schedules[]
  workHours              WorkHours[]
  vacations              Vacations[]
  expenseActors          ExpenseActor[]
  timeAdjustmentRequests TimeAdjustmentRequest[]
}

model Vendors {
  id               Int      @id @default(autoincrement())
  name             String
  address_id       Int
  store_name       String
  cnpj             String   @unique
  status           Int
  phone            String
  cel_number       String
  deliver          Boolean
  volume_purchases Float
  purchases        Float
  invoicing        Float
  created_at       DateTime @default(now())
  updated_at       DateTime

  address Adresses @relation(fields: [address_id], references: [id])

  materialOrders MaterialOrders[]
  expenseActors  ExpenseActor[]
}

model Products {
  id           Int      @id @default(autoincrement())
  status       Int
  volume_sales Float
  sales        Float
  invoicing    Float
  name         String
  model        String
  size         String
  character    String
  moldes       Int
  equivalency  Float
  created_at   DateTime @default(now())
  updated_at   DateTime

  materialOrders  MaterialOrders[]
  orders          OrderItems[]
  prices          Prices[]
  stock           Stock[]
  salesForecasts  SalesForecasts[]
  expenseProducts ExpenseProducts[]
  // Relacionamentos para receitas
  productRecipes  ProductRecipe[]   @relation("ProductRecipes")
}

model Locations {
  id         Int      @id @default(autoincrement())
  name       String
  code       String   @unique
  status     Int      @default(1)
  position_x Float    @default(0)
  position_y Float    @default(0)
  width      Float    @default(100)
  height     Float    @default(100)
  color      String   @default("#3b82f6")
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  machines Machines[]
  stocks   Stock[]
}

model Machines {
  id              Int      @id @default(autoincrement())
  model           String
  machine_number  Int
  status          Int
  location_id     Int?
  location_status Int
  created_at      DateTime @default(now())
  updated_at      DateTime

  location        Locations?        @relation(fields: [location_id], references: [id])
  expenseMachines ExpenseMachines[]
}

model Procedures {
  id                Int                 @id @default(autoincrement())
  process_name      String
  status            Int
  workers           Int
  created_at        DateTime            @default(now())
  updated_at        DateTime
  expenseProcedures ExpenseProcedures[]
}

model Schedules {
  id          Int      @id @default(autoincrement())
  employee_id Int
  day_of_week Int
  start_time  String   @default("09:00:00")
  end_time    String   @default("18:00:00")
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  employee Employees @relation(fields: [employee_id], references: [id])

  @@index([employee_id, day_of_week], name: "employee_dayOfWeek_idx")
}

model WorkHours {
  id          Int       @id @default(autoincrement())
  employee_id Int
  clock_in    DateTime
  clock_out   DateTime?
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt

  employee              Employees               @relation(fields: [employee_id], references: [id])
  timeAdjustmentRequests TimeAdjustmentRequest[]
}

model Vacations {
  id          Int      @id @default(autoincrement())
  employee_id Int
  start_date  DateTime
  end_date    DateTime
  sold_days   Int
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  employee Employees @relation(fields: [employee_id], references: [id])
}

model TimeConfiguration {
  id                    Int      @id @default(autoincrement())
  day_of_week           Int
  work_start            String   @default("09:00:00")
  work_end              String   @default("18:00:00")
  late_limit_in_minutes Int
  created_at            DateTime @default(now())
  updated_at            DateTime @updatedAt
}

enum TimeAdjustmentStatus {
  PENDING
  APPROVED
  REJECTED
}

model TimeAdjustmentRequest {
  id                 Int                  @id @default(autoincrement())
  employee_id        Int
  work_hour_id       Int?                 // Referencia ao ponto especifico (null = novo ponto)
  original_clock_in  DateTime             // Horario original de entrada
  original_clock_out DateTime?            // Horario original de saida
  proposed_clock_in  DateTime?            // Nova entrada proposta
  proposed_clock_out DateTime?            // Nova saida proposta
  reason             String?              // Justificativa (opcional)
  status             TimeAdjustmentStatus @default(PENDING)
  admin_comment      String?              // Comentario do admin (obrigatorio ao revisar)
  reviewed_by        Int?                 // ID do admin que revisou
  reviewed_at        DateTime?            // Data da revisao
  created_at         DateTime             @default(now())
  updated_at         DateTime             @updatedAt

  employee  Employees  @relation(fields: [employee_id], references: [id])
  work_hour WorkHours? @relation(fields: [work_hour_id], references: [id])

  @@index([employee_id])
  @@index([work_hour_id])
  @@index([status])
}

//TODO: Review 1 order could have n products.
model Orders {
  id          Int      @id @default(autoincrement())
  final_price Float
  date        DateTime
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt
  customer_id Int

  customer Customers @relation(fields: [customer_id], references: [id])

  payments          Payments[]
  productReturns    ProductReturns[]
  products          OrderItems[]
  invoice           Invoice?
  deliveries        Delivery[]
  productionControl ProductionControl[]
  labelPrints       LabelPrints[]
  expenseActors     ExpenseActor[]
  expenseOrders     ExpenseOrders[]
}

model OrderItems {
  order_id   Int
  product_id Int
  quantity   Int
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  order   Orders   @relation(fields: [order_id], references: [id])
  product Products @relation(fields: [product_id], references: [id])

  @@id([order_id, product_id])
}

model Payments {
  id             Int      @id @default(autoincrement())
  amount_paid    Float
  remaining      Float
  payment_method String
  date           DateTime
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  order_id Int

  order Orders @relation(fields: [order_id], references: [id])
}

model MaterialOrders {
  id               Int      @id @default(autoincrement())
  date             DateTime
  amount           Int
  unit             String
  storage_location String
  received_by      String
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt
  product_id       Int
  vendor_id        Int

  product              Products              @relation(fields: [product_id], references: [id])
  vendor               Vendors               @relation(fields: [vendor_id], references: [id])
  // Relacionamento para consumo
  materialConsumptions MaterialConsumption[]
  // Relacionamento para receitas (MaterialOrders como matéria-prima)
  productRecipes       ProductRecipe[]
}

//TODO: Review delivery logic
model ProductReturns {
  id                    Int      @id @default(autoincrement())
  return_reason         String
  replacement_necessary Boolean
  resold                Boolean
  date                  DateTime
  created_at            DateTime @default(now())
  updated_at            DateTime @updatedAt

  order_id Int

  order Orders @relation(fields: [order_id], references: [id])

  returnedLabels ReturnedLabels[]
}

model ReturnedLabels {
  id          Int     @id @default(autoincrement())
  ticket_code String  @unique
  opened      Boolean
  quantity    Int

  product_return_id Int

  product_return ProductReturns @relation(fields: [product_return_id], references: [id])
}

model Prices {
  id                 Int       @id @default(autoincrement())
  product_id         Int
  customer_id        Int? // Pode ser null para preços padrão
  production_cost    Float // Custo de produção
  operational_margin Float // Margem operacional
  final_price        Float // Preço final
  second_line_price  Float? // Preço segunda linha
  frozen_until       DateTime? // Data até quando o preço está congelado
  status             String // ex: "amarelo", "verde", etc
  last_update        DateTime  @updatedAt
  created_at         DateTime  @default(now())

  product  Products   @relation(fields: [product_id], references: [id])
  customer Customers? @relation(fields: [customer_id], references: [id])

  @@unique([product_id, customer_id])
}

model Expenses {
  id                     Int      @id @default(autoincrement())
  amount                 Decimal  @db.Decimal(12, 2)
  classification         String?  @db.VarChar(50)
  description            String?  @db.VarChar(150)
  justification          String
  requires_reimbursement Boolean
  applies_all_products   Boolean
  applies_all_machines   Boolean
  expense_date           DateTime
  expense_actor_id       Int
  created_at             DateTime @default(now())
  created_by             String?
  updated_at             DateTime @updatedAt
  updated_by             String?

  actor      ExpenseActor        @relation(fields: [expense_actor_id], references: [id])
  machines   ExpenseMachines[]
  products   ExpenseProducts[]
  procedures ExpenseProcedures[]
  orders     ExpenseOrders[]

  @@index([expense_actor_id])
}

model ExpenseActor {
  id                Int      @id @default(autoincrement())
  first_name        String?  @db.VarChar(100)
  last_name         String?  @db.VarChar(100)
  whatsapp_telegram String?  @db.VarChar(20)
  store_name        String?  @db.VarChar(150)
  vendor_id         Int?
  employee_id       Int?
  customer_id       Int?
  order_id          Int?
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  vendor   Vendors?   @relation(fields: [vendor_id], references: [id])
  employee Employees? @relation(fields: [employee_id], references: [id])
  customer Customers? @relation(fields: [customer_id], references: [id])
  order    Orders?    @relation(fields: [order_id], references: [id])
  expenses Expenses[]

  @@index([vendor_id])
  @@index([employee_id])
  @@index([customer_id])
  @@index([order_id])
}

model ExpenseMachines {
  expense_id Int
  machine_id Int

  expense Expenses @relation(fields: [expense_id], references: [id])
  machine Machines @relation(fields: [machine_id], references: [id])

  @@id([expense_id, machine_id])
}

model ExpenseProducts {
  expense_id Int
  product_id Int

  expense Expenses @relation(fields: [expense_id], references: [id])
  product Products @relation(fields: [product_id], references: [id])

  @@id([expense_id, product_id])
}

model ExpenseProcedures {
  expense_id   Int
  procedure_id Int

  expense   Expenses   @relation(fields: [expense_id], references: [id])
  procedure Procedures @relation(fields: [procedure_id], references: [id])

  @@id([expense_id, procedure_id])
}

model ExpenseOrders {
  expense_id Int
  order_id   Int

  expense Expenses @relation(fields: [expense_id], references: [id])
  order   Orders   @relation(fields: [order_id], references: [id])

  @@id([expense_id, order_id])
}

enum MessageTriggerType {
  SCHEDULED
  EVENT
  MANUAL
}

enum MessageTargetTable {
  CUSTOMER
  ORDER
  PAYMENT
  DELIVERY
}

model CustomerMessageConfig {
  id                       Int      @id @default(autoincrement())
  customer_id              Int
  can_whatsapp             Boolean  @default(false)
  can_whatsapp_attachments Boolean  @default(false)
  can_telegram             Boolean  @default(false)
  can_telegram_attachments Boolean  @default(false)
  can_email                Boolean  @default(false)
  can_email_attachments    Boolean  @default(false)
  created_at               DateTime @default(now())
  updated_at               DateTime @updatedAt

  // Relacionamento com a tabela de clientes
  customer Customers @relation(fields: [customer_id], references: [id])

  // Relacionamento com a tabela de horários/dias
  schedules CustomerMessageSchedule[]
}

model CustomerMessageSchedule {
  id                Int      @id @default(autoincrement())
  message_config_id Int
  day_of_week       Int // 0 = Domingo, 1 = Segunda, ..., 6 = Sábado
  can_send          Boolean  @default(false)
  start_time        String? // Formato "HH:mm"
  end_time          String? // Formato "HH:mm"
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  // Relacionamento com a configuração de mensagens
  message_config CustomerMessageConfig @relation(fields: [message_config_id], references: [id])
}

model MessageConfig {
  id           String             @id @default(uuid())
  customer_id  String
  can_whatsapp Boolean            @default(false)
  can_email    Boolean            @default(false)
  can_sms      Boolean            @default(false)
  trigger_type MessageTriggerType
  target_table MessageTargetTable
  is_active    Boolean            @default(true)
  created_at   DateTime           @default(now())
  updated_at   DateTime           @updatedAt
  schedules    MessageSchedule[]
}

model MessageSchedule {
  id         String        @id @default(uuid())
  config_id  String
  config     MessageConfig @relation(fields: [config_id], references: [id])
  cron       String
  timezone   String
  is_active  Boolean       @default(true)
  created_at DateTime      @default(now())
  updated_at DateTime      @updatedAt

  @@index([config_id])
}

model MessageTemplate {
  id          String   @id @default(uuid())
  name        String
  description String?
  subject     String?
  content     String
  variables   Json?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt
}

model Invoice {
  id         Int      @id @default(autoincrement())
  order_id   Int      @unique
  order      Orders   @relation(fields: [order_id], references: [id])
  number     String // número da nota fiscal
  status     String // status da nota (emitida, recebida, pendente, etc)
  type       String // tipo da nota (avulsa, registro pendente, etc)
  issue_date DateTime // data de emissão
  recipient  String? // destinatário (opcional, para histórico)
  note       String? // observações ou campo livre
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
}

model Packaging {
  id               Int      @id @default(autoincrement())
  name             String
  quantity         Int
  storage_location String
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  customers  CustomerPackaging[]
  deliveries DeliveryPackaging[]
}

//TODO: Don't forget to implement this functionality in the frontend
model CustomerPackaging {
  id             Int      @id @default(autoincrement())
  customer_id    Int
  packaging_id   Int
  pontalti_brand Boolean  @default(false)
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  customer  Customers @relation(fields: [customer_id], references: [id])
  packaging Packaging @relation(fields: [packaging_id], references: [id])

  @@unique([customer_id, packaging_id])
}

model Delivery {
  id            Int      @id @default(autoincrement())
  order_id      Int
  status        Int // 1: Em planejamento, 2: Em rota, 3: Entregue
  delivery_date DateTime
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  order      Orders              @relation(fields: [order_id], references: [id])
  packagings DeliveryPackaging[]
}

//TODO: Don't forget to implement this functionality in the frontend
model DeliveryPackaging {
  id           Int      @id @default(autoincrement())
  delivery_id  Int
  packaging_id Int
  quantity     Int
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  delivery  Delivery  @relation(fields: [delivery_id], references: [id])
  packaging Packaging @relation(fields: [packaging_id], references: [id])

  @@unique([delivery_id, packaging_id])
}

model Stock {
  id          Int      @id @default(autoincrement())
  amount      Int
  location_id Int?
  product_id  Int
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  product  Products   @relation(fields: [product_id], references: [id])
  location Locations? @relation(fields: [location_id], references: [id])
}

// Receita de produtos (define quais materiais são necessários para produzir cada produto)
model ProductRecipe {
  id                Int      @id @default(autoincrement())
  product_id        Int // Produto final
  material_order_id Int // MaterialOrder que serve como matéria-prima
  quantity_needed   Float // Quantidade necessária do material para produzir 1 unidade do produto
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  product        Products       @relation("ProductRecipes", fields: [product_id], references: [id])
  material_order MaterialOrders @relation(fields: [material_order_id], references: [id])

  @@unique([product_id, material_order_id])
}

// Consumo de materiais por produção (aproveitando MaterialOrders existente)
model MaterialConsumption {
  id                    Int       @id @default(autoincrement())
  production_control_id Int
  material_order_id     Int // Referencia MaterialOrders existente
  planned_consumption   Float // Consumo planejado
  actual_consumption    Float? // Consumo real (preenchido após produção)
  variance              Float? // Variação entre planejado e real
  consumption_date      DateTime? // Data do consumo real
  created_at            DateTime  @default(now())
  updated_at            DateTime  @updatedAt

  production_control ProductionControl @relation(fields: [production_control_id], references: [id])
  material_order     MaterialOrders    @relation(fields: [material_order_id], references: [id])

  @@unique([production_control_id, material_order_id])
}

model ProductionControl {
  id                     Int       @id @default(autoincrement())
  order_id               Int
  status                 Int // Status da produção (1: Planejamento, 2: Em produção, 3: Concluído, etc)
  material_disponibility Int // Disponibilidade geral de materiais (1: Disponível, 2: Parcial, 3: Indisponível)
  estimated_start_date   DateTime? // Data estimada de início
  estimated_end_date     DateTime? // Data estimada de conclusão
  actual_start_date      DateTime? // Data real de início
  actual_end_date        DateTime? // Data real de conclusão
  production_priority    Int       @default(3) // 1: Urgente, 2: Alta, 3: Normal, 4: Baixa
  observations           String? // Observações gerais
  created_at             DateTime  @default(now())
  updated_at             DateTime  @updatedAt

  order                Orders                @relation(fields: [order_id], references: [id])
  material_consumption MaterialConsumption[]
}

model SalesForecasts {
  id                  Int       @id @default(autoincrement())
  customer_id         Int
  product_id          Int
  status              Int
  reason              String?
  next_estimated_date DateTime?
  frequency_days      Int?
  quantity            Int
  created_at          DateTime  @default(now())
  created_by          String?
  updated_at          DateTime  @updatedAt
  updated_by          String?

  customer Customers @relation(fields: [customer_id], references: [id])
  product  Products  @relation(fields: [product_id], references: [id])

  @@index([customer_id])
  @@index([product_id])
}

model LabelPrints {
  id         Int      @id @default(autoincrement())
  order_id   Int
  created_at DateTime @default(now())
  created_by String?
  updated_at DateTime @updatedAt
  updated_by String?

  order Orders @relation(fields: [order_id], references: [id])

  @@index([order_id])
}
